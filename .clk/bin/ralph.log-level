#!/usr/bin/env bash
# [[file:../../src/ralph.org::*log-level][log-level:1]]
ROOT='/home/sam/prog/daggerlib'
set -eu

source "_clk.sh"

clk_usage () {
    cat<<EOF
$0

Change the verbosity of a running ralph's output

Levels:
  normal   filtered, categorized output (default)
  think    normal + claude thinking content
  verbose  show every line, truncated
  json     show every line raw
--
O:--consul-key:str:Consul KV key for stop signaling:ralph/dagger/status
A:level:str:Log level (normal, think, verbose, json). Omit to show current level.
EOF
}

clk_help_handler "$@"

CONSUL_KEY="$(clk_value consul-key)"

if [ -z "${CONSUL_HTTP_ADDR:-}" ]; then
    echo "error: CONSUL_HTTP_ADDR is not set" >&2
    exit 1
fi

LEVEL="${CLK___LEVEL:-}"

if [ -z "${LEVEL}" ]; then
    current="$(consul kv get "${CONSUL_KEY}/log-level" 2>/dev/null || echo "normal")"
    echo "${current}"
    exit 0
fi

case "${LEVEL}" in
    normal|think|verbose|json) ;;
    *)
        echo "error: invalid level '${LEVEL}' (must be normal, think, verbose, json)" >&2
        exit 1
        ;;
esac

consul kv put "${CONSUL_KEY}/log-level" "${LEVEL}" > /dev/null
echo "[ralph.log-level] set to '${LEVEL}'"
# log-level:1 ends here
